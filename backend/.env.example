# Copy to .env and fill in. Never commit .env.
CONNECT_REMOTE_USERNAME=you@example.com
CONNECT_REMOTE_PASSWORD=changeme
CONNECT_REMOTE_PIN=1234

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CONNECT_REMOTE_API_TOKEN=changeme

# Optional overrides (defaults shown)
# CONNECT_REMOTE_GENESIS_REGION=1        # hyundai_kia_connect_api region code (1 = EU)
# CONNECT_REMOTE_GENESIS_BRAND=3         # brand code (3 = Genesis)
# CONNECT_REMOTE_REFRESH_MIN_INTERVAL_SECONDS=900
# CONNECT_REMOTE_REFRESH_DAILY_CAP=20
# CONNECT_REMOTE_CORS_ORIGINS=*
